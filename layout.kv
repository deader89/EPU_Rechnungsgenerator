<InfoPopup>:
    size_hint: 0.8, 0.6
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            id: message_label
            text: root.message
            text_size: self.width, None
            markup: True
            halign: 'center'
            valign: 'middle'
        Button:
            text: "OK"
            size_hint_y: None
            height: '45dp'
            on_release: root.dismiss()

<BackupPasswordPopup>:
    title: "ZIP-Passwort festlegen"
    size_hint: 0.8, 0.4
    auto_dismiss: False
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            text: "Erstelle ein zusätzliches Passwort für dieses ZIP-Backup:"
        TextInput:
            id: zip_pwd
            password: True
            multiline: False
            on_text_validate: app.process_restore(self.text, root)
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Weiter"
                on_release: app.open_backup_filechooser(zip_pwd.text, root)

<BackupFileChooserPopup>:
    title: "Speicherort für Backup wählen"
    size_hint: 0.9, 0.9
    BoxLayout:
        orientation: 'vertical'
        spacing: '10dp'
        FileChooserListView:
            id: filechooser
            filters: ['*.zip']
            path: app.user_data_dir
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            TextInput:
                id: filename
                text: app.get_default_backup_name()
                size_hint_x: 0.6
                multiline: False
                on_text_validate: app.process_backup(filechooser.path, self.text, root)
            Button:
                text: "Abbrechen"
                size_hint_x: 0.2
                on_release: root.dismiss()
            Button:
                text: "Speichern"
                size_hint_x: 0.2
                on_release: app.process_backup(filechooser.path, filename.text, root)

<RestoreFileChooserPopup>:
    title: "Backup-Datei (.zip) auswählen"
    size_hint: 0.9, 0.9
    BoxLayout:
        orientation: 'vertical'
        spacing: '10dp'
        FileChooserListView:
            id: filechooser
            filters: ['*.zip']
            path: app.user_data_dir
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Auswählen"
                on_release: app.open_restore_password(filechooser.selection, root)

<RestorePasswordPopup>:
    title: "ZIP-Passwort eingeben"
    size_hint: 0.8, 0.4
    auto_dismiss: False
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            text: "Bitte gib das zusätzliche Passwort für dieses ZIP-Archiv ein:"
        TextInput:
            id: zip_pwd
            password: True
            multiline: False
            on_text_validate: app.open_backup_filechooser(self.text, root)
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Einspielen"
                on_release: app.process_restore(zip_pwd.text, root)

<RechnungenExportPopup>:
    title: "Speicherort für Rechnungen ZIP wählen"
    size_hint: 0.9, 0.9
    BoxLayout:
        orientation: 'vertical'
        spacing: '10dp'
        FileChooserListView:
            id: filechooser
            path: app.user_data_dir
            dirselect: True
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            TextInput:
                id: filename
                text: "Rechnungen_Export.zip"
                size_hint_x: 0.6
                multiline: False
                on_text_validate: app.process_rechnungen_export(filechooser.path, self.text, root)
            Button:
                text: "Abbrechen"
                size_hint_x: 0.2
                on_release: root.dismiss()
            Button:
                text: "Exportieren"
                size_hint_x: 0.2
                on_release: app.process_rechnungen_export(filechooser.path, filename.text, root)

<AppResetPopup>:
    title: "ACHTUNG: App zurücksetzen!"
    size_hint: 0.8, 0.5
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            text: "[color=ff4444]WARNUNG:[/color]\nMöchtest du die Datenbank wirklich komplett löschen und die App zurücksetzen?\n\nAlle ungesicherten Daten gehen unwiderruflich verloren!"
            markup: True
            text_size: self.width, None
            halign: 'center'
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Ja, alles löschen"
                background_color: (0.9, 0.2, 0.2, 1)
                on_release: root.reset_app()

<LogoAuswahlPopup>:
    title: "Logo Bild auswählen"
    size_hint: 0.9, 0.9
    BoxLayout:
        orientation: 'vertical'
        spacing: '10dp'
        FileChooserListView:
            id: filechooser
            filters: ['*.png', '*.jpg', '*.jpeg', '*.PNG', '*.JPG']
            path: app.user_data_dir
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Auswählen"
                on_release: root.auswaehlen(filechooser.selection)

<OSSelectionPopup>:
    title: "Ersteinrichtung: Betriebssystem wählen"
    size_hint: 0.9, 0.7
    auto_dismiss: False
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            text: "Für die optimale Kompatibilität beim Öffnen und Drucken von PDFs,\nwähle bitte dein aktuelles Betriebssystem:"
            text_size: self.width, None
            halign: 'center'
        GridLayout:
            cols: 2
            spacing: '10dp'
            Button:
                text: "Windows"
                on_release: root.select_os("windows")
            Button:
                text: "macOS / Linux"
                on_release: root.select_os("unix")
            Button:
                text: "Android / iOS"
                on_release: root.select_os("mobile")

<LoginScreen>:
    name: 'login'
    BoxLayout:
        orientation: 'vertical'
        padding: '20dp'
        spacing: '15dp'
        
        Widget:
        
        Label:
            id: error_lbl
            text: "Login"
            color: 1, 0.3, 0.3, 1
            size_hint_y: None
            height: '50dp'
            font_size: '16sp'
            text_size: self.width, None
            halign: 'center'
        TextInput:
            id: pwd_input
            password: True
            multiline: False
            hint_text: "Master-Passwort"
            size_hint_y: None
            height: '45dp'
            font_size: '16sp'
            on_text_validate: root.do_login()
        TextInput:
            id: pwd_confirm
            password: True
            multiline: False
            hint_text: "Passwort wiederholen"
            opacity: 0
            size_hint_y: None
            height: 0
            font_size: '16sp'
            on_text_validate: root.do_login()
        ClickableRow:
            id: dsgvo_box
            size_hint_y: None
            height: 0
            opacity: 0
            spacing: '10dp'
            on_release: dsgvo_checkbox.active = not dsgvo_checkbox.active
            PassiveCheckBox:
                id: dsgvo_checkbox
                size_hint_x: None
                width: '60dp'
            Label:
                text: "Ich verstehe, dass diese App nur ein technisches Hilfsmittel ist.\nFür die Einhaltung der DSGVO und gesetzlichen Pflichten (Aufbewahrungsfristen) bin ich vollumfänglich selbst verantwortlich."
                text_size: self.width, None
                halign: 'left'
                valign: 'middle'
                font_size: '12sp'
        Button:
            id: btn_login
            text: "Entsperren"
            size_hint_y: None
            height: '45dp'
            font_size: '16sp'
            on_release: root.do_login()
            
        Widget:

<MainScreen>:
    name: 'main'
    BoxLayout:
        orientation: 'vertical'
        padding: '20dp'
        spacing: '15dp'
        Label:
            text: "Rechnungs-Tool: Hauptmenü"
            font_size: '22sp'
        Button:
            text: "Neue Rechnung erstellen"
            on_release: app.generiere_rechnung()
        Button:
            text: "Rechnungen verwalten"
            on_release: app.oeffne_rechnungen_verwalten()
        Button:
            text: "Einstellungen"
            on_release: app.root.current = 'einstellungen'
        Button:
            text: "Datenbank & Backup"
            on_release: app.root.current = 'datenbank'
        Button:
            text: "Sperren"
            on_release: app.lock_app()

<DatenbankScreen>:
    name: 'datenbank'
    BoxLayout:
        orientation: 'vertical'
        padding: '20dp'
        spacing: '15dp'
        Label:
            text: "Datenbankverwaltung"
            font_size: '22sp'
        Button:
            text: "Backup erstellen"
            on_release: app.backup_erstellen()
        Button:
            text: "Backup einspielen"
            on_release: app.backup_einspielen()
        Button:
            text: "Rechnungen als ZIP exportieren"
            on_release: app.rechnungen_exportieren()
        LongPressButton:
            text: "App zurücksetzen (Gedrückt halten)"
            background_color: (0.9, 0.2, 0.2, 1)
            on_release: app.show_info("Hinweis", "Bitte den Button für ca. 2 Sekunden gedrückt halten, um die App zurückzusetzen.")
            on_long_press: app.zeige_reset_popup()
        Button:
            text: "Zurück"
            on_release: app.root.current = 'main'

<EinstellungenScreen>:
    name: 'einstellungen'
    BoxLayout:
        orientation: 'vertical'
        padding: '10dp'
        spacing: '10dp'
        Label:
            text: "Einstellungen"
            font_size: '20sp'
            size_hint_y: None
            height: '40dp'
        ScrollView:
            GridLayout:
                id: fields_container
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: '10dp'
        BoxLayout:
            size_hint_y: None
            height: '90dp'
            orientation: 'vertical'
            spacing: '10dp'
            BoxLayout:
                size_hint_y: None
                height: '40dp'
                spacing: '10dp'
                Button:
                    text: "Datenschutzerklärung"
                    on_release: app.open_datenschutzerklaerung()
                Button:
                    text: "Über die App / Lizenzen"
                    on_release: app.open_about()
            BoxLayout:
                size_hint_y: None
                height: '40dp'
                spacing: '10dp'
                Button:
                    text: "Zurück"
                    on_release: app.root.current = 'main'
                Button:
                    text: "Speichern"
                    on_release: root.speichern()

<DatenschutzerklaerungPopup>:
    title: "Datenschutzerklärung"
    size_hint: 0.9, 0.9
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '10dp'
        Label:
            text: "Text der Datenschutzerklärung:"
            size_hint_y: None
            height: '35dp'
            text_size: self.size
            halign: 'left'
        TextInput:
            id: txt_dsgvo
            multiline: True
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "PDF export"
                on_release: root.als_pdf_exportieren()
            Button:
                text: "Speichern"
                on_release: root.speichern()

<AboutPopup>:
    title: "Über die App & Rechtliche Hinweise"
    size_hint: 0.9, 0.9
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '10dp'
        TextInput:
            readonly: True
            text: "EPU Rechnungsgenerator\n\nHAFTUNGSAUSSCHLUSS (DISCLAIMER)\nDie Software wird \"wie besehen\" (as-is) zur Verfügung gestellt, ohne jegliche ausdrückliche oder stillschweigende Garantie. Der Entwickler übernimmt keinerlei Haftung für Datenverlust, fehlerhafte Berechnungen, steuerrechtliche Fehler oder datenschutzrechtliche Verstöße, die durch die Nutzung der Software entstehen.\n\nDer Nutzer ist vollumfänglich selbst für die Richtigkeit der Rechnungen, die Erstellung von Backups, die Einhaltung der gesetzlichen Aufbewahrungsfristen (z.B. BAO) und der DSGVO verantwortlich.\n\nVERWENDETE OPEN SOURCE SOFTWARE\nDiese Anwendung basiert auf Open-Source-Technologien. Vielen Dank an die Entwickler folgender Bibliotheken:\n- Python (PSF License)\n- Kivy (MIT License)\n- ReportLab (BSD License)\n- fpdf2 (LGPL License)\n- Cryptography (Apache/BSD License)\n- pycryptodome (BSD/Public Domain)\n- qrcode (BSD License)\n- plyer (MIT License)\n- pyjnius (MIT License)"
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            Button:
                text: "Schließen"
                on_release: root.dismiss()

<KundeLoeschenPopup>:
    title: "Kunde endgültig löschen?"
    size_hint: 0.8, 0.5
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            text: "Möchtest du diesen Kunden endgültig aus der Datenbank entfernen?\nDiese Aktion kann nicht rückgängig gemacht werden!" + ("\n\n[color=ff4444]" + root.warn_text + "[/color]" if root.warn_text else "")
            markup: True
            text_size: self.width, None
            halign: 'center'
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Trotzdem löschen" if root.warn_text else "Ja, Kunde löschen"
                background_color: (0.9, 0.2, 0.2, 1) if root.warn_text else (1, 1, 1, 1)
                on_release: root.loeschen()

<KundeVerwaltenPopup>:
    title: "Kunde hinzufügen/verwalten"
    size_hint: 0.9, 0.9
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '10dp'
        
        Spinner:
            id: kv_spinner
            text: "Bestehenden Kunden laden..."
            size_hint_y: None
            height: '45dp'
            on_text: root.lade_kunden_daten(self.text)
            
        ScrollView:
            GridLayout:
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: '10dp'
                
                TextInput:
                    id: kv_name
                    hint_text: "Kundenname (Pflichtfeld)"
                    size_hint_y: None
                    height: '45dp'
                    multiline: False
                    on_text: root.check_existing(self.text)
                    on_text_validate: root.speichern()
                    
                ClickableRow:
                    size_hint_y: None
                    height: '40dp'
                    on_release: kv_einmalig.active = not kv_einmalig.active
                    PassiveCheckBox:
                        id: kv_einmalig
                        size_hint_x: None
                        width: '60dp'
                    Label:
                        text: "Nur für diese Rechnung (nicht dauerhaft speichern)"
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                        
                TextInput:
                    id: kv_adresse
                    hint_text: "Adresse (Straße, PLZ, Ort) (Pflichtfeld)"
                    multiline: True
                    size_hint_y: None
                    height: '90dp'
                    
                TextInput:
                    id: kv_uid
                    hint_text: "Kunden-UID (optional)"
                    size_hint_y: None
                    height: '45dp'
                    multiline: False
                    
                TextInput:
                    id: kv_email
                    hint_text: "E-Mail für Rechnungen (optional)"
                    size_hint_y: None
                    height: '45dp'
                    multiline: False
                    
                TextInput:
                    id: kv_zz
                    hint_text: "Individuelles Zahlungsziel in Tagen (optional)"
                    size_hint_y: None
                    height: '45dp'
                    input_filter: 'int'
                    multiline: False
                    
                BoxLayout:
                    size_hint_y: None
                    height: '45dp'
                    spacing: '10dp'
                    TextInput:
                        id: kv_sk_prozent
                        hint_text: "Indiv. Skonto in %"
                        input_filter: 'float'
                        multiline: False
                    TextInput:
                        id: kv_sk_tage
                        hint_text: "Skonto-Frist in Tagen"
                        input_filter: 'int'
                        multiline: False
                        
                TextInput:
                    id: kv_pdf_pwd
                    hint_text: "Individuelles PDF-Passwort (optional)"
                    size_hint_y: None
                    height: '45dp'
                    multiline: False

        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                id: btn_dsgvo
                text: "DSGVO Auskunft"
                disabled: True
                on_release: root.dsgvo_auskunft()
            Button:
                id: btn_delete_kunde
                text: "Löschen"
                disabled: True
                background_color: (0.8, 0.2, 0.2, 1)
                on_release: root.kunde_loeschen_abfrage()
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Übernehmen"
                on_release: root.speichern()

<GespeichertePositionLoeschenPopup>:
    title: "Position aus Datenbank löschen?"
    size_hint: 0.8, 0.4
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            text: "Möchtest du '" + root.position_name + "' dauerhaft löschen?\n\nDieser Vorgang kann nicht rückgängig gemacht werden."
            text_size: self.width, None
            halign: 'center'
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Löschen"
                on_release: root.loeschen()

<PositionLoeschenPopup>:
    title: "Position löschen?"
    size_hint: 0.8, 0.4
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            text: "Möchtest du diese Position wirklich löschen?"
            text_size: self.width, None
            halign: 'center'
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Löschen"
                on_release: root.loeschen()

<ZeitraumPopup>:
    title: "Zeitraum für Position festlegen"
    size_hint: 0.9, None
    height: '240dp'
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '10dp'
        Label:
            text: "Bitte Jahr eingeben (z.B. 2024):" if root.mode == "Jahr" else "Bitte Monat und Jahr eingeben (z.B. 02 und 26):"
            text_size: self.width, None
            halign: 'center'
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            TextInput:
                id: monat_input
                hint_text: "Monat (MM)"
                input_filter: 'int'
                multiline: False
                on_text_validate: root.uebernehmen()
            TextInput:
                id: jahr_input
                hint_text: "Jahr (JJJJ)" if root.mode == "Jahr" else "Jahr (JJ)"
                input_filter: 'int'
                multiline: False
                on_text_validate: root.uebernehmen()
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Übernehmen"
                on_release: root.uebernehmen()

<PositionItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: '45dp'
    padding: '5dp'
    spacing: '5dp'
    canvas.before:
        Color:
            rgba: 0.2, 0.2, 0.25, 1
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: root.beschr
        size_hint_x: 0.35
        text_size: self.size
        halign: 'left'
        valign: 'middle'
    Label:
        text: root.menge
        size_hint_x: 0.1
    Label:
        text: root.einh
        size_hint_x: 0.1
    Label:
        text: root.mwst
        size_hint_x: 0.15
    Label:
        text: root.ep
        size_hint_x: 0.15
    Label:
        text: root.ges
        size_hint_x: 0.15

<PdfAktionPopup>:
    title: "PDF Erfolgreich erstellt!"
    size_hint: 0.8, 0.8
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '10dp'
        Label:
            text: "Was möchtest du mit der Rechnung tun?"
            text_size: self.width, None
            halign: 'center'
        Button:
            text: "Anzeigen"
            on_release: root.anzeigen()
        Button:
            text: "Drucken"
            on_release: root.drucken()
        Button:
            text: "Speichern"
            on_release: root.speichern()
        Button:
            text: "Passwortgeschützt speichern (mit Kunden-Passwort)"
            on_release: root.speichern_pw()
        Button:
            text: "Per E-Mail senden"
            on_release: root.send_email()
            opacity: 1 if root.has_email else 0
            disabled: not root.has_email
            size_hint_y: None
            height: dp(45) if root.has_email else 0
        Button:
            text: "Per E-Mail senden (mit Kunden-Passwort)"
            on_release: root.send_email_pw()
            opacity: 1 if root.has_email else 0
            disabled: not root.has_email
            size_hint_y: None
            height: dp(45) if root.has_email else 0
        Button:
            text: "Abbrechen"
            on_release: root.dismiss()

<PdfSpeichernPopup>:
    title: "PDF Speichern unter..."
    size_hint: 0.9, 0.9
    BoxLayout:
        orientation: 'vertical'
        spacing: '10dp'
        FileChooserListView:
            id: filechooser
            path: app.user_data_dir
            dirselect: True
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            TextInput:
                id: filename
                text: root.default_filename
                size_hint_x: 0.6
                multiline: False
                on_text_validate: root.save_pdf(filechooser.path, self.text)
            Button:
                text: "Abbrechen"
                size_hint_x: 0.2
                on_release: root.dismiss()
            Button:
                text: "Speichern"
                size_hint_x: 0.2
                on_release: root.save_pdf(filechooser.path, filename.text)

<PdfPasswortPopup>:
    title: "Passwort für PDF festlegen"
    size_hint: 0.8, 0.5
    BoxLayout:
        orientation: 'vertical'
        padding: '15dp'
        spacing: '15dp'
        Label:
            text: "Das Kunden-Passwort wurde vorausgefüllt.\nDu kannst es hier für dieses PDF anpassen:" if root.has_kunden_pw else "Kein Kunden-Passwort hinterlegt.\nBitte gib ein Passwort für dieses PDF ein:"
            text_size: self.width, None
            halign: 'center'
        TextInput:
            id: pdf_pw
            password: True
            size_hint_y: None
            height: '45dp'
            hint_text: "Passwort eingeben"
            multiline: False
            on_text_validate: root.weiter()
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "Abbrechen"
                on_release: root.dismiss()
            Button:
                text: "Weiter"
                on_release: root.weiter()

<RechnungScreen>:
    name: 'rechnung'
    BoxLayout:
        orientation: 'vertical'
        spacing: '10dp'
        Label:
            id: rn_label
            text: "Rechnungsnummer: "
            font_size: '18sp'
            size_hint_y: None
            height: '35dp'
        
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '5dp'
            TextInput:
                id: kunde_suche
                hint_text: "Kunde suchen..."
                on_text: root.filter_kunden(self.text)
                size_hint_x: 0.3
            Spinner:
                id: kunde_spinner
                text: "Kunde wählen"
                size_hint_x: 0.4
            Button:
                text: "Kunde verwalten"
                size_hint_x: 0.3
                on_release: app.oeffne_kunde_verwalten()

        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '5dp'
            TextInput:
                id: pos_suche
                hint_text: "Pos. suchen/Neue Pos."
                on_text: root.filter_positionen(self.text)
                size_hint_x: 0.3
                multiline: False
                on_text_validate: root.position_hinzufuegen()
            Spinner:
                id: pos_spinner
                text: "Position wählen"
                on_text: root.fuelle_position(self.text)
                size_hint_x: 0.4
            Button:
                text: "Pos. löschen"
                size_hint_x: 0.3
                on_release: root.gespeicherte_position_loeschen()

        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '5dp'
            NumericFloatInput:
                id: menge_input
                hint_text: "Menge"
                input_filter: 'float'
                size_hint_x: 0.15
                multiline: False
                on_text_validate: root.position_hinzufuegen()
            Spinner:
                id: einheit_input
                text: "Stk"
                values: ["Stk", "Std", "Pauschal", "Pauschal Monat", "Jahr", "kg", "g", "t", "m²", "cm", "km", "Lm", "Min", ""]
                on_text: root.check_einheit(self.text)
                size_hint_x: 0.15
            Spinner:
                id: mwst_input
                text: "20%"
                values: ["20%", "13%", "10%", "0%"]
                size_hint_x: 0.15
            NumericFloatInput:
                id: preis_input
                hint_text: "Preis Brutto"
                input_filter: 'float'
                size_hint_x: 0.25
                multiline: False
                on_text_validate: root.position_hinzufuegen()
            Button:
                text: "Hinzufügen"
                size_hint_x: 0.3
                on_release: root.position_hinzufuegen()

        BoxLayout:
            size_hint_y: None
            height: '35dp'
            canvas.before:
                Color:
                    rgba: 0.3, 0.3, 0.3, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            Label:
                text: "Beschreibung"
                size_hint_x: 0.35
            Label:
                text: "Menge"
                size_hint_x: 0.1
            Label:
                text: "Einh."
                size_hint_x: 0.1
            Label:
                text: "MwSt"
                size_hint_x: 0.15
            Label:
                text: "EP Brutto"
                size_hint_x: 0.15
            Label:
                text: "Gesamt"
                size_hint_x: 0.15
            
        ScrollView:
            BoxLayout:
                id: positionen_liste
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: '2dp'
        
        BoxLayout:
            size_hint_y: None
            height: '45dp'
            spacing: '10dp'
            Button:
                text: "PDF Erstellen"
                on_release: root.pdf_erstellen()
            Button:
                text: "Zurück"
                on_release: app.root.current = 'main'